# User Messages
msgid "Welcome, {username}! Your account has been created successfully."
msgstr "Добро пожаловать, {username}! Ваш аккаунт успешно создан."

msgid ""
"As an author, you must read and accept our article writing rules before "
"publishing."
msgstr ""
"Как автор, вы должны прочитать и принять наши правила написания статей перед"
" публикацией."

msgid "Registration failed. Please correct the errors below."
msgstr "Регистрация не удалась. Пожалуйста, исправьте ошибки ниже."

msgid "Invalid username or password. Please try again."
msgstr "Неверное имя пользователя или пароль. Попробуйте снова."

msgid "You have been logged out successfully."
msgstr "Вы успешно вышли из системы."

msgid "Access denied. This page is only for authors."
msgstr "Доступ запрещен. Эта страница только для авторов."

msgid ""
"Article rules have not been configured yet. Please contact the "
"administrator."
msgstr ""
"Правила статей еще не настроены. Пожалуйста, свяжитесь с администратором."

msgid "Thank you for accepting the rules! You can now create articles."
msgstr "Спасибо за принятие правил! Теперь вы можете создавать статьи."

msgid "You must accept the rules to proceed."
msgstr "Вы должны принять правила для продолжения."

msgid "Please accept the article writing rules to start publishing."
msgstr ""
"Пожалуйста, примите правила написания статей, чтобы начать публикацию."

msgid "Please log in to access this page."
msgstr "Пожалуйста, войдите в систему для доступа к этой странице."

msgid "Access denied. Only authors can create articles."
msgstr "Доступ запрещен. Только авторы могут создавать статьи."

msgid "You must accept the article writing rules before creating articles."
msgstr "Вы должны принять правила написания статей перед созданием статей."

msgid "Access denied. You can only edit your own articles."
msgstr "Доступ запрещен. Вы можете редактировать только свои статьи."

msgid "Access denied. You can only delete your own articles."
msgstr "Доступ запрещен. Вы можете удалять только свои статьи."

